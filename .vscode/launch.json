{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "CyberCat Chatbot Web",
      "url": "http://localhost:4100",
      "webRoot": "${workspaceFolder}/apps/chatbot",
      "sourceMaps": true
    },
    {
      "name": "CyberCat Service",
      "type": "debugpy",
      "request": "launch",
      "program": "src/main.py",
      "console": "internalConsole",
      "cwd": "${workspaceFolder}/apps/service",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "redirectOutput": true
    }
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": ["CyberCat Chatbot Web", "CyberCat Service"]
    }
  ]
}
