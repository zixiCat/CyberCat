{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "editor-browser",
      "request": "launch",
      "name": "CyberCat Web",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}/apps/web",
      "sourceMaps": true,
      "preLaunchTask": "CyberCat Web Server"
    },
    {
      "name": "CyberCat Service",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${env:USERPROFILE}\\scoop\\shims\\fnm.exe",
      "runtimeArgs": ["exec", "--using=default", "--", "npm.cmd", "run", "start:service"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ],
  "compounds": [
    {
      "name": "CyberCat Full Stack",
      "configurations": ["CyberCat Service", "CyberCat Web"],
      "stopAll": true
    }
  ]
}